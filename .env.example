# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to Git.

# Generate a new key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_new_actual_key_here

# Supabase credentials (can remain VITE_ prefixed – they are public keys)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: change the port the Express dev server listens on
PORT=3000
